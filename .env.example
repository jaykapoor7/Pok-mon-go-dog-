# ─────────────────────────────────────────────────────────────
# StrayPaw Delhi — environment variables
#
# Add these in Vercel (Project → Settings → Environment Variables) for the
# live, public app. Locally, copy this file to `.env.local` and fill it in.
#
# With NO Supabase keys the app still runs against built-in demo data — handy
# for local development, but uploads won't persist. For the real launch you
# want all three NEXT_PUBLIC_ values set.
# ─────────────────────────────────────────────────────────────

# Supabase (https://app.supabase.com → Project Settings → API)
# These are safe to expose to the browser — writes are guarded by RLS and
# SECURITY DEFINER functions (see supabase/schema.sql). Posting needs no login.
# Sign-in (email magic link) is optional and lets users manage their own
# sightings + dog status from any device — run supabase/auth-accounts.sql and
# set the Site URL under Supabase → Authentication → URL Configuration.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Demo Mode — overlay ~40 isolated sample sightings on the map so it looks
# active. Read-only, never written to the database. Defaults ON; set to
# "false" to turn off once you have real activity.
NEXT_PUBLIC_DEMO_MODE=true

# Your canonical site URL (no trailing slash). REQUIRED for the X/Twitter link
# preview image to show — it makes the og:image an absolute URL on your domain.
# e.g. https://straypaw.kapoorjay.com
NEXT_PUBLIC_SITE_URL=

# Mapbox GL access token (https://account.mapbox.com/access-tokens/)
# Without this the app renders a stylised — but fully interactive — fallback map.
NEXT_PUBLIC_MAPBOX_TOKEN=

# ── Spam protection (Cloudflare Turnstile — free) ───────────────
# https://dash.cloudflare.com → Turnstile → Add site (get both keys).
# When BOTH are set, the report form requires a human check that is verified
# server-side before any sighting is saved. Leave blank to disable.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Server-only Supabase service role key (Settings → API → service_role).
# Lets the protected /api/report route write after the Turnstile check.
# NEVER prefix this with NEXT_PUBLIC — it must stay server-side.
SUPABASE_SERVICE_ROLE_KEY=

# Admin secret for the moderation endpoint (/api/admin/sightings).
# Any long random string. Used to list/approve/reject pending sightings.
# Requires SUPABASE_SERVICE_ROLE_KEY to be set too. Server-side only.
ADMIN_SECRET=
