# ─────────────────────────────────────────────────────────────
# StrayPaw Delhi — environment variables
#
# Add these in Vercel (Project → Settings → Environment Variables) for the
# live, public app. Locally, copy this file to `.env.local` and fill it in.
#
# With NO Supabase keys the app still runs against built-in demo data — handy
# for local development, but uploads won't persist. For the real launch you
# want all three NEXT_PUBLIC_ values set.
# ─────────────────────────────────────────────────────────────

# Supabase (https://app.supabase.com → Project Settings → API)
# These are safe to expose to the browser — writes are guarded by RLS and
# SECURITY DEFINER functions (see supabase/schema.sql). No login required.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Mapbox GL access token (https://account.mapbox.com/access-tokens/)
# Without this the app renders a stylised fallback map of Delhi.
NEXT_PUBLIC_MAPBOX_TOKEN=
