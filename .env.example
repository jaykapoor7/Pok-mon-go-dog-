# ─────────────────────────────────────────────────────────────
# StrayPaw Delhi — environment variables
#
# The app runs fully in a rich DEMO MODE with zero configuration.
# Add these keys to switch from demo data to a live Supabase + Mapbox stack.
# ─────────────────────────────────────────────────────────────

# Mapbox GL access token (https://account.mapbox.com/access-tokens/)
# Without this the app renders a stylised fallback map of Delhi.
NEXT_PUBLIC_MAPBOX_TOKEN=

# Supabase project (https://app.supabase.com → Project Settings → API)
# Without these the app uses in-memory demo data.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-side only — used for NGO bulk operations / admin tasks.
SUPABASE_SERVICE_ROLE_KEY=
